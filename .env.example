# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required: read-only personal access token.
# Recommended: fine-grained PAT with "Contents: Read-only" and "Metadata: Read-only"
# on "All repositories" for the account.
GITHUB_TOKEN=your_token_here

# Optional — uncomment to override defaults:
# MIRROR_DIR=/data
# DB_PATH=/var/lib/github-mirror/state.db
# SYNC_INTERVAL=1h
# CONCURRENCY=4
# INCLUDE_LFS=true
# GIT_TIMEOUT=30m
# LOG_LEVEL=info
